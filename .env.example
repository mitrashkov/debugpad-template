# DebugPad Configuration
# Copy this file to .env.local and fill in your values

# OpenRouter API Key - Required for AI features
# Get your key at: https://openrouter.ai/keys
# DebugPad never stores or transmits your API key. It stays in your browser.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter Model Selection (optional - defaults to anthropic/claude-3.5-sonnet)
# See available models: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# OpenRouter Site URL (optional - for rankings on openrouter.ai)
# This identifies your app to OpenRouter
OPENROUTER_SITE_URL=http://localhost:3000

# OpenRouter App Name (optional)
OPENROUTER_APP_NAME=DebugPad

# DebugPad App URL
# Used for self-referential links and callbacks
APP_URL=http://localhost:3000

# Note: All API calls are made directly from your browser to OpenRouter.
# Your API key and code never touch our servers.
